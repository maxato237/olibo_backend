# Flask
SECRET_KEY=
JWT_SECRET_KEY=

# Mode debug (true uniquement en dev local)
DEBUG=false

# Base de données
# Production (Sevalla) : renseigner DATABASE_URL (fourni par Sevalla dans les variables d'env)
# Exemple : postgresql://olibo:PASSWORD@olibo-database-siv8e-postgresql.olibo-database-siv8e.svc.cluster.local:5432/oliboBd
DATABASE_URL=

# Développement local uniquement (ignoré si DATABASE_URL est défini)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=
LOCAL_DB_NAME=oliboBd

# CORS — liste des origines autorisées séparées par des virgules
# Exemple prod : https://mon-app.sevalla.app,https://olibo.cm
CORS_ORIGINS=http://localhost:4200

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
